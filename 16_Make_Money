    int t;
    cin >> t;
    while (t--)
    {
        int n, x, c;
        cin >> n >> x >> c;
        vector<int> a(n);
        for (int i = 0; i < n; i++)
        {
            cin >> a[i];
        }

        int count = 0;
        int temp;
        int sum1 = 0;
        for (int i = 0; i < n; i++)
        {
            sum1 = sum1 + max(a[i], x - c);  // we find the digit max or when we subtract c from x that is max 
        }

        cout << sum1 << endl;
    }
}
